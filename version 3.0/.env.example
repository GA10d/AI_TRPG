# AI TRPG 3.0 server_proxy multi-model examples
# Copy this file to `.env` or `.env.local`, then start `npm.cmd run dev:server`

# Shared runtime tuning
TRPG_SERVER_PROXY_TEMPERATURE=0.7
TRPG_SERVER_PROXY_TIMEOUT_MS=60000
# Optional
# TRPG_SERVER_PROXY_MAX_TOKENS=800

# Generic fallback keys
# If a profile-specific key is missing, the server may still fall back to these.
TRPG_SERVER_PROXY_API_KEY=
TRPG_SERVER_PROXY_MODEL=
TRPG_SERVER_PROXY_BASE_URL=

# ChatGPT / OpenAI
# Default model profile id in UI: `chatgpt`
OPENAI_API_KEY=
TRPG_CHATGPT_MODEL=gpt-5.4
# Leave empty to use https://api.openai.com/v1
TRPG_CHATGPT_BASE_URL=

# DeepSeek
# Default model profile ids in UI: `deepseek-chat` / `deepseek-reasoner`
DEEPSEEK_API_KEY=
TRPG_DEEPSEEK_MODEL=deepseek-chat
TRPG_DEEPSEEK_REASONER_TIMEOUT_MS=180000
TRPG_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini OpenAI-compatible mode
# Default model profile id in UI: `gemini`
GEMINI_API_KEY=
# Optional fallback alias also supported by the server:
# GOOGLE_API_KEY=
TRPG_GEMINI_MODEL=gemini-3-pro-preview
TRPG_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Doubao / Volcengine Ark
# Default model profile id in UI: `doubao`
DOUBAO_API_KEY=
# Optional official alias also supported:
# ARK_API_KEY=
# Optional dedicated alias also supported:
# TRPG_DOUBAO_API_KEY=
TRPG_DOUBAO_MODEL=doubao-seed-2-0-pro-260215
TRPG_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Image generation providers
# Default image profile id in UI: `mock-image`

# Gemini native image generation
# Fast profile id in UI: `gemini-image`
# Standard / pro profile id in UI: `gemini-image-pro`
TRPG_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# TRPG_GEMINI_IMAGE_PRO_MODEL=gemini-3-pro-image-preview
TRPG_GEMINI_IMAGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ChatGPT / OpenAI image generation
# Standard profile id in UI: `chatgpt-image`
# Fast profile id in UI: `chatgpt-image-fast`
# Optional dedicated alias if you want to separate text/image keys:
# TRPG_CHATGPT_IMAGE_API_KEY=
TRPG_CHATGPT_IMAGE_MODEL=gpt-image-1.5
# TRPG_CHATGPT_IMAGE_FAST_MODEL=gpt-image-1-mini
TRPG_CHATGPT_IMAGE_BASE_URL=https://api.openai.com/v1

# Doubao / Volcengine Ark Seedream image generation
# Standard profile id in UI: `doubao-image`
# Fast profile id in UI: `doubao-image-fast`
# Optional dedicated alias if you want to separate text/image keys:
# TRPG_DOUBAO_IMAGE_API_KEY=
TRPG_DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
# TRPG_DOUBAO_IMAGE_FAST_MODEL=doubao-seedream-5-0-lite-260128
TRPG_DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Custom OpenAI-compatible provider
# Default model profile id in UI: `custom-openai-compatible`
TRPG_CUSTOM_OPENAI_API_KEY=
TRPG_CUSTOM_OPENAI_MODEL=
TRPG_CUSTOM_OPENAI_BASE_URL=
