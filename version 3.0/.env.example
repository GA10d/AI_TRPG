# server_proxy 最小配置示例
# 复制为 .env 或 .env.local 后再启动 dev:server

TRPG_SERVER_PROXY_DEPENDENCE=OpenAI
TRPG_SERVER_PROXY_MODEL=gpt-4.1-mini
# OpenAI 原生可留空，默认会走 https://api.openai.com/v1
# 如果你接的是 OpenAI-compatible 服务，就写成自己的 base url
TRPG_SERVER_PROXY_BASE_URL=

# 优先读取 TRPG_SERVER_PROXY_API_KEY
# 如果 dependence=OpenAI，也支持直接使用 OPENAI_API_KEY
TRPG_SERVER_PROXY_API_KEY=

TRPG_SERVER_PROXY_TEMPERATURE=0.7
TRPG_SERVER_PROXY_TIMEOUT_MS=60000
# 可选
# TRPG_SERVER_PROXY_MAX_TOKENS=800
