# Copy this file to `.env` or `.env.local`, then start:
# npm.cmd run dev

# Optional port override
PORT=4316

# Text generation providers for comic title/description
OPENAI_API_KEY=
COMIC_OPENAI_TEXT_MODEL=gpt-4o-mini
COMIC_OPENAI_TEXT_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=
COMIC_DEEPSEEK_TEXT_MODEL=deepseek-chat
COMIC_DEEPSEEK_TEXT_BASE_URL=https://api.deepseek.com/v1

GEMINI_API_KEY=
GOOGLE_API_KEY=
COMIC_GEMINI_TEXT_MODEL=gemini-2.5-flash
COMIC_GEMINI_TEXT_BASE_URL=https://generativelanguage.googleapis.com/v1beta

DOUBAO_API_KEY=
ARK_API_KEY=
COMIC_DOUBAO_TEXT_MODEL=doubao-seed-2-0-pro-260215
COMIC_DOUBAO_TEXT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

COMIC_CUSTOM_TEXT_API_KEY=
COMIC_CUSTOM_TEXT_MODEL=
COMIC_CUSTOM_TEXT_BASE_URL=

# Image generation providers for comic pages
COMIC_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
COMIC_GEMINI_IMAGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

COMIC_OPENAI_IMAGE_MODEL=gpt-image-1.5
COMIC_OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
# Optional dedicated image key. Falls back to OPENAI_API_KEY.
COMIC_OPENAI_IMAGE_API_KEY=

COMIC_DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
COMIC_DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Optional dedicated image key. Falls back to DOUBAO_API_KEY / ARK_API_KEY.
COMIC_DOUBAO_IMAGE_API_KEY=
